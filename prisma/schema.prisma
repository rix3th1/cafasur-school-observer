generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum docType {
  CC
  CE
  TI
  PASSPORT
}

enum role {
  STUDENT
  TEACHER
  ADMIN
}

enum Grade {
  PRESCHOOL
  FIRST
  SECOND
  THIRD
  FOURTH
  FIFTH
  SIXTH
  SEVENTH
  EIGHTH
  NINTH
  TENTH
  ELEVENTH
}

enum GradeGroup {
  A
  B
  C
  D
  E
}

model User {
  id             Int     @id @default(autoincrement())
  docNumber      String  @unique
  docType        docType
  name           String
  lastName       String
  email          String  @unique
  hashedPassword String
  role           role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student?
  teacher Teacher?
}

model Student {
  id     Int        @id @default(autoincrement())
  userId Int        @unique
  user   User       @relation(fields: [userId], references: [id])
  grade  Grade
  group  GradeGroup

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentBehaviorRecords StudentBehaviorRecord[]
}

model Teacher {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentBehaviorRecords StudentBehaviorRecord[]
}

enum Severity {
  I
  II
  III
}

enum CodeOfConductStatus {
  ACTIVE
  INACTIVE
}

model CodeOfConduct {
  id          Int                 @id @default(autoincrement())
  code        String              @unique // ART-001, ART-002, etc.
  description String
  severity    Severity
  penalty     String
  status      CodeOfConductStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentBehaviorRecords StudentBehaviorRecord[]
}

enum RecordType {
  POSSITIVE
  NEGATIVE
}

enum RecordCategory {
  PRAISE
  MISCONDUCT
  OBSERVATION
}

enum RecordStatus {
  PENDING
  RESOLVED
  APPEALED
}

model StudentBehaviorRecord {
  id               Int            @id @default(autoincrement())
  studentId        Int
  student          Student        @relation(fields: [studentId], references: [id])
  type             RecordType
  category         RecordCategory
  teacherId        Int
  teacher          Teacher        @relation(fields: [teacherId], references: [id])
  codeOfConductId  Int?
  codeOfConduct    CodeOfConduct? @relation(fields: [codeOfConductId], references: [id])
  title            String
  description      String
  correctiveAction String?
  status           RecordStatus?  @default(PENDING)
  date             DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
